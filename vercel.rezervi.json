{
  "buildCommand": "yarn build",
  "installCommand": "yarn install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "devCommand": "yarn dev",
  "regions": ["fra1"],
  "env": {
    "NEXT_PUBLIC_WEBAPP_URL": "https://cal.rezervi.rs",
    "NEXTAUTH_URL": "https://cal.rezervi.rs",
    "NEXT_PUBLIC_LICENSE_CONSENT": "true",
    "NEXT_PUBLIC_DISABLE_SIGNUP": "true"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://rezervi.rs https://*.rezervi.rs http://localhost:*"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://rezervi.rs"
        }
      ]
    }
  ]
}
